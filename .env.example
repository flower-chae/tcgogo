# ============================================
# docker compose 환경변수 (.env로 복사하여 사용)
# ============================================

# OpenAI API Key (필수)
OPENAI_API_KEY=sk-your-key-here

# PostgreSQL 설정
POSTGRES_USER=deepagent
POSTGRES_PASSWORD=deepagent1234
POSTGRES_DB=deepagent
POSTGRES_PORT=5432

# 서비스 포트 (충돌 시 변경)
BACKEND_PORT=3480
FRONTEND_PORT=3482

# Frontend API 주소 (브라우저에서 접근하는 주소)
# 로컬 개발: http://localhost:3480/api/v1
# 배포 서버: https://your-domain.com/api/v1
NUXT_PUBLIC_API_BASE=http://localhost:3480/api/v1
